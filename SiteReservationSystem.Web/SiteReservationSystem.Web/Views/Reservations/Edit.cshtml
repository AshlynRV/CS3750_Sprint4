@model SiteReservationSystem.Web.Models.Reservation

@{
    ViewData["Title"] = "Edit Reservation";
    var isPCS = Context.Session.GetInt32("IsPCSOrders") == 1;
}

<h2>Edit Reservation</h2>

<div class="mb-4">
    <h5>Reservation #@Model.ReservationID</h5>
    <p><strong>Current Total:</strong> @Model.TotalAmount.ToString("C")</p>
</div>

<form asp-controller="Home" asp-action="EditReservation" method="post">
    <input type="hidden" asp-for="ReservationID" />
    <input type="hidden" asp-for="ReservationStatusID" />

    <div asp-validation-summary="All" class="text-danger mb-3"></div>

    <div class="mb-3">
        <label asp-for="StartDate" class="form-label"></label>
        <input asp-for="StartDate" type="date" class="form-control" />
        <span asp-validation-for="StartDate" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="EndDate" class="form-label"></label>
        <input asp-for="EndDate" type="date" class="form-control" />
        <span asp-validation-for="EndDate" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="TrailerLengthFeet" class="form-label">Trailer Length (feet)</label>
        <input asp-for="TrailerLengthFeet" type="number" class="form-control" />
        <span asp-validation-for="TrailerLengthFeet" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="SiteID" class="form-label">Site</label>
        <select asp-for="SiteID" class="form-control">
            @foreach (var site in ViewBag.Sites)
            {
                <option value="@site.SiteID" selected="@(site.SiteID == Model.SiteID)">
                    Site @site.SiteNumber
                </option>
            }
        </select>
        <span asp-validation-for="SiteID" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="Notes" class="form-label">Special Requests / Notes</label>
        <textarea asp-for="Notes" class="form-control"></textarea>
        <span asp-validation-for="Notes" class="text-danger"></span>
    </div>

    <button type="submit" class="btn btn-primary">Save Changes</button>
    <a asp-controller="Home" asp-action="MyReservations" class="btn btn-secondary">Back to My Reservations</a>
</form>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
    <script>
        var isPCS = @isPCS.ToString().ToLower();

        function isPeakSeason(date) {
            var month = date.getMonth();
            return month >= 3 && month <= 9;
        }

        function limitEndDate() {
            var startInput = document.getElementById('StartDate');
            var endInput = document.getElementById('EndDate');
            var tomorrow = new Date();
            tomorrow.setDate(tomorrow.getDate() + 1);

            if (!startInput.value) {
                startInput.value = tomorrow.toISOString().split('T')[0];
            }

            startInput.min = tomorrow.toISOString().split('T')[0];

            var startDate = new Date(startInput.value);
            var minEnd = new Date(startDate);
            minEnd.setDate(minEnd.getDate() + 1);
            endInput.min = minEnd.toISOString().split('T')[0];

            if (isPeakSeason(startDate) && !isPCS) {
                var maxStay = 14;
                var maxEnd = new Date(startDate);
                maxEnd.setDate(maxEnd.getDate() + maxStay);
                endInput.max = maxEnd.toISOString().split('T')[0];

                var currentEnd = new Date(endInput.value);
                if (currentEnd > maxEnd) {
                    endInput.value = maxEnd.toISOString().split('T')[0];
                }
            } else {
                endInput.removeAttribute('max');
            }
        }

        document.getElementById('StartDate')?.addEventListener('change', limitEndDate);

        window.onload = function() {
            limitEndDate();
        };

        document.querySelector('form').addEventListener('submit', function(e) {
            var startDate = new Date(document.getElementById('StartDate').value);
            var endDate = new Date(document.getElementById('EndDate').value);
            var stayLength = Math.ceil((endDate - startDate) / (1000 * 60 * 60 * 24));

            if (!isPCS && isPeakSeason(startDate) && stayLength > 14) {
                e.preventDefault();
                alert('Maximum stay is 14 days during peak season.');
                return false;
            }
        });
    </script>
}