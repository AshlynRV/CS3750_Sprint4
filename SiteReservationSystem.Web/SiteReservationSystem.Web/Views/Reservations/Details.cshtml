@*
    For more information on enabling MVC for empty projects, visit https://go.microsoft.com/fwlink/?LinkID=397860
    @model IEnumerable<SiteReservationSystem.Web.Models.ReservationFee>
*@

@{
    ViewData["Title"] = "Details";
}
<h2>Reservation Details</h2>

<h3> Fees: </h3>
<table class="table"> 
    <thead>
        <tr>
            <th>Fee Name</th>
            <th>Amount</th>
            <th>Manage</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var rf in Model.ReservationFees)
        {
            <tr>
                <td>@rf.Fee.FeeName</td>
                <td>@rf.Amount.ToString("C")</td>
                <td>
                    <form asp-action="DeleteReservationFee" asp-controller="Fees" asp-route-id="@rf.ReservationFeeID" method="post"
                    onsubmit="return confirm('Remove this fee from this reservation?');">
                    <button type="submit" class="btn btn-sm btn-danger">Delete</button>
                </form>
                </td>
            </tr>
        }
    </tbody>
</table>
<a asp-action="Index" class="btn btn-secondary">Cancel</a>
