@model IEnumerable<SiteReservationSystem.Web.Models.Reservation>

@{
    ViewData["Title"] = "Reservations";
}
<style>
    .table thead th {
        white-space: nowrap;
        vertical-align: middle;
        text-align: center;
    }
    .table tbody td {
        vertical-align: middle;
        text-align: center;
    }
    .table td:nth-child(3), .table td:nth-child(4), .table td:last-child, .table th:last-child {
        white-space: nowrap;
    }
    .btn-sm {
        white-space: nowrap;
        margin: 2px;
    }
</style>
<h2>Reservations</h2>

<div class="row mb-3">
    <div class="col-md-3">
        <form method="get" class="d-flex gap-2">
            <input type="hidden" name="reservationId" value="@Context.Request.Query["reservationId"]" />
            <input type="hidden" name="customerName" value="@Context.Request.Query["customerName"]" />
            <input type="hidden" name="startDate" value="@Context.Request.Query["startDate"]" />
            <input type="hidden" name="endDate" value="@Context.Request.Query["endDate"]" />
            <select name="filterStatus" class="form-select" onchange="this.form.submit()">
                <option value="">All Statuses</option>
                <option value="1" selected="@(Context.Request.Query["filterStatus"] == "1")">Upcoming</option>
                <option value="2" selected="@(Context.Request.Query["filterStatus"] == "2")">In Progress</option>
                <option value="3" selected="@(Context.Request.Query["filterStatus"] == "3")">Completed</option>
                <option value="4" selected="@(Context.Request.Query["filterStatus"] == "4")">Cancelled</option>
            </select>
        </form>
    </div>
</div>

@* Search form for filtering reservations by ID, customer name, and date range *@
<form method="get" class="row mb-3">
    <div class="col">
        <input type="number" name="reservationId"
               value="@Context.Request.Query["reservationId"]"
               class="form-control" placeholder="Reservation #" />
    </div>

    <div class="col">
        <input type="text" name="customerName"
               value="@Context.Request.Query["customerName"]"
               class="form-control" placeholder="Customer Name" />
    </div>

    <div class="col">
        <input type="date" name="startDate"
               value="@Context.Request.Query["startDate"]"
               class="form-control" />
    </div>

    <div class="col">
        <input type="date" name="endDate"
               value="@Context.Request.Query["endDate"]"
               class="form-control" />
    </div>

    <div class="col">
        <button type="submit" class="btn btn-primary">Search</button>
        <a href="/Reservations" class="btn btn-secondary">Clear</a>
    </div>
</form>

<button onclick="window.print()" class="btn btn-secondary mb-2">
    Print / Save as PDF
</button>

@* Displays filtered reservation results *@
<table class="table table-bordered table-hover">
    <thead>
        <tr>
            <th>Reservation #</th>
            <th>Customer Name</th>
            <th>Phone</th>
            <th>Email</th>
            <th>Site Number</th>
            <th>Start Date</th>
            <th>End Date</th>
            <th>Status</th>
            <th>Actions</th>
        </tr>
    </thead>
    <tbody>
        @if (!Model.Any())
        {
            <tr>
                <td colspan="10" class="text-center">
                    No reservations found.
                </td>
            </tr>
        }
        else
        {
            foreach (var r in Model)
            {
                <tr>
                    <td>@r.ReservationID</td>
                    <td>@r.Customer.FirstName @r.Customer.LastName</td>
                    <td>@r.Customer.PhoneNumber</td>
                    <td>@r.Customer.User.Email</td>
                    <td>@r.Site.SiteNumber</td>
                    <td>@r.StartDate.ToShortDateString()</td>
                    <td>@r.EndDate.ToShortDateString()</td>
                    <td>@r.ReservationStatus.StatusName</td>
                    <td>
                        <a asp-action="Details"
                               asp-route-id="@r.ReservationID"
                               class="btn btn-info btn-sm">
                            Details
                        </a>
                        <a asp-action="Edit"
                               asp-route-id="@r.ReservationID"
                               class="btn btn-warning btn-sm">
                            Edit
                        </a>
                        <a asp-action="AddFee" asp-controller="Fees" asp-route-reservationId="@r.ReservationID" class="btn btn-danger btn-sm">Add Fee</a>
                        @if (r.Invoice != null)
                        {
                            <a asp-controller="Payments" asp-action="Index" 
                               asp-route-reservationId="@r.ReservationID"
                               asp-route-invoiceId="@r.Invoice.InvoiceID"
                               class="btn btn-success btn-sm">
                                Invoice
                            </a>
                        }
                    </td>
                </tr>
            }
        }
    </tbody>
</table>

@section Scripts 
{
    @{
        @if (TempData["FeeMessage"] != null)
        {
            <script type="text/javascript">
                window.onload = function() {
                    alert("@TempData["FeeMessage"]");
                };
            </script>
        }
    }
}
