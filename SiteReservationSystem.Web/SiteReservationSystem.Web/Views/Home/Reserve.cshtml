@model SiteReservationSystem.Web.ViewModels.CreateReservationViewModel
@{
    ViewData["Title"] = "Reserve Site";
    var isPCS = ViewBag.IsPCSOrders == true;
}
<h2 class="mb-4">Reserve Site</h2>

<div class="row">
    <div class="col-md-7">
        <form asp-action="Reserve" method="post" class="card p-4 shadow-sm">
            <input type="hidden" asp-for="SiteID" />

            <div class="mb-3">
                <label asp-for="StartDate" class="form-label">Start Date</label>
                <input asp-for="StartDate" type="date" id="startDate" class="form-control" min="@DateTime.Today.AddDays(1).ToString("yyyy-MM-dd")" />
            </div>

            <div class="mb-3">
                <label asp-for="EndDate" class="form-label">End Date</label>
                <input asp-for="EndDate" type="date" id="endDate" class="form-control" min="@DateTime.Today.AddDays(1).ToString("yyyy-MM-dd")" />
            </div>

            <div class="mb-3">
                <label class="form-label">Bringing Trailer</label>
                <select id="bringOwnSelect" class="form-control" onchange="toggleTrailer()">
                    <option value="false">No</option>
                    <option value="true">Yes</option>
                </select>
            </div>

            <div class="mb-3" id="trailerLengthContainer" style="display: none;">
                <label asp-for="TrailerLengthFeet" class="form-label">Trailer Length</label>
                <input asp-for="TrailerLengthFeet" id="TrailerLengthFeet" type="number" class="form-control" />
            </div>

            <div class="mb-3">
                <label asp-for="NumberOfGuests" class="form-label">Number of Guests</label>
                <input asp-for="NumberOfGuests" type="number" class="form-control" value="1" min="0" />
            </div>

            <div class="mb-3">
                <label asp-for="NumberOfPets" class="form-label">Number of Pets</label>
                <input asp-for="NumberOfPets" type="number" class="form-control" value="0" min="0" />
            </div>

            <div class="mb-3">
                <label asp-for="SpecialRequests" class="form-label">Special Requests</label>
                <textarea asp-for="SpecialRequests" class="form-control" rows="3"></textarea>
            </div>

            <button type="submit" class="btn btn-success w-100">
                Confirm Reservation
            </button>
        </form>
    </div>

    <div class="col-md-5">
        <div class="card p-4 shadow-sm bg-light">
            <h5>Reservation Info</h5>
            <hr />
            <p><strong>Site Number:</strong> @Model.SiteNumber</p>
            <p class="text-muted">Please review your reservation details before submitting.</p>
        </div>
    </div>
</div>

<script>
    function toggleTrailer() {
        var select = document.getElementById("bringOwnSelect");
        var container = document.getElementById("trailerLengthContainer");
        if (select.value === "true") {
            container.style.display = "block";
        } else {
            container.style.display = "none";
        }
    }

    window.onload = function() {
        var lengthInput = document.getElementById("TrailerLengthFeet");
        var select = document.getElementById("bringOwnSelect");
        if (parseFloat(lengthInput.value) > 0) {
            select.value = "true";
        }
        toggleTrailer();
        limitEndDate();
    };

    function isPeakSeason(date) {
        var month = date.getMonth();
        return month >= 3 && month <= 9;
    }

    function limitEndDate() {
        var startInput = document.getElementById('startDate');
        var endInput = document.getElementById('endDate');
        var isPCS = @((ViewBag.IsPCSOrders == true).ToString().ToLower());
        
        var tomorrow = new Date();
        tomorrow.setDate(tomorrow.getDate() + 1);
        
        if (!startInput.value) {
            startInput.value = tomorrow.toISOString().split('T')[0];
        }
        
        startInput.min = tomorrow.toISOString().split('T')[0];
        
        var startDate = new Date(startInput.value);
        var minEnd = new Date(startDate);
        minEnd.setDate(minEnd.getDate() + 1);
        endInput.min = minEnd.toISOString().split('T')[0];
        
        if (isPeakSeason(startDate) && !isPCS) {
            var maxStay = 14;
            var maxEnd = new Date(startDate);
            maxEnd.setDate(maxEnd.getDate() + maxStay);
            endInput.max = maxEnd.toISOString().split('T')[0];
            
            var currentEnd = new Date(endInput.value);
            if (currentEnd > maxEnd) {
                endInput.value = maxEnd.toISOString().split('T')[0];
            }
        } else {
            endInput.removeAttribute('max');
        }
    }

    document.getElementById('startDate')?.addEventListener('change', limitEndDate);
</script>