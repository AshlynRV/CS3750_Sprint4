@model IEnumerable<SiteReservationSystem.Web.Models.Reservation>

@{
    ViewData["Title"] = "My Reservations";
}

<h2>My Reservations</h2>

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-info alert-dismissible fade show" role="alert">
        @TempData["SuccessMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

@if (TempData["PriceDifference"] != null)
{
    <div class="alert alert-info">
        <strong>Pricing Updated:</strong><br />
        Old Total: @decimal.Parse(TempData["OldTotalAmount"]!.ToString()!).ToString("C")<br />
        New Total: @decimal.Parse(TempData["NewTotalAmount"]!.ToString()!).ToString("C")<br />
        Difference: @decimal.Parse(TempData["PriceDifference"]!.ToString()!).ToString("C")
    </div>
}

@if (!Model.Any())
{
    <p>You do not have any reservations yet.</p>
}
else
{
    <table class="table table-bordered">
        <thead>
            <tr>
                <th>Reservation #</th>
                <th>Site</th>
                <th>Site Type</th>
                <th>Start Date</th>
                <th>End Date</th>
                <th>Status</th>
                <th>Total</th>
                <th>Balance Due</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var reservation in Model)
            {
                var isCancelled = reservation.ReservationStatus.StatusName == "Cancelled";
                <tr>
                    <td>@reservation.ReservationID</td>
                    <td>@reservation.Site.SiteNumber</td>
                    <td>@reservation.Site.SiteType.TypeName</td>
                    <td>@reservation.StartDate.ToShortDateString()</td>
                    <td>@reservation.EndDate.ToShortDateString()</td>
                    <td>
                        @if (isCancelled)
                        {
                            <span class="badge bg-danger">Cancelled</span>
                        }
                        else
                        {
                            @reservation.ReservationStatus.StatusName
                        }
                    </td>
                    <td>@reservation.TotalAmount.ToString("C")</td>
                    <td>
                        @if (reservation.BalanceDue > 0)
                        {
                            <span class="text-danger fw-bold">@reservation.BalanceDue.ToString("C") Owed</span>
                        }
                        else if (reservation.BalanceDue < 0)
                        {
                            <span class="text-success fw-bold">@Math.Abs(reservation.BalanceDue).ToString("C") Refund Due</span>
                        }
                        else
                        {
                            <span class="text-success">Paid</span>
                        }
                    </td>
                    <td>
                        @if (!isCancelled)
                        {
                            var isUpcoming = reservation.ReservationStatus.StatusName == "Upcoming";
                            
                            @if (isUpcoming)
                            {
                                <a asp-action="EditReservation"
                                       asp-route-id="@reservation.ReservationID"
                                       class="btn btn-primary btn-sm">
                                    Edit
                                </a>

                                <form asp-action="CancelReservation"
                                      asp-route-id="@reservation.ReservationID"
                                      method="post"
                                      class="d-inline">
                                    @Html.AntiForgeryToken()
                                    <button type="submit"
                                            class="btn btn-danger btn-sm"
                                            onclick="return confirm('Are you sure you want to cancel this reservation? A cancellation fee may apply.');">
                                        Cancel
                                    </button>
                                </form>
                            }
                        }
                        @if (reservation.BalanceDue > 0)
                        {
                            <a asp-controller="Payments" asp-action="Index" class="btn btn-success btn-sm">
                                Pay Now
                            </a>
                        }
                        @if (reservation.BalanceDue < 0)
                        {
                            <a asp-controller="Payments" asp-action="Index" class="btn btn-warning btn-sm">
                                View Refund
                            </a>
                        }
                        @if (reservation.BalanceDue == 0 && (isCancelled || reservation.ReservationStatus.StatusName != "Upcoming"))
                        {
                            <button class="btn btn-secondary btn-sm" disabled>None</button>
                        }
                    </td>
                </tr>
            }
        </tbody>
    </table>
}
