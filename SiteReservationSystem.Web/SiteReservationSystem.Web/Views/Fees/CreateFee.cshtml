@model SiteReservationSystem.Web.Models.Fee
@{
    ViewData["Title"] = "Create Fee";
}
<h2>Create Fee</h2>

<form asp-action="CreateFee" method="post">

    <div class="form-group">
        <label asp-for="FeeName">Fee Name:</label>
        <input asp-for="FeeName" class="form-control border-primary-subtle" />
        <span asp-validation-for="FeeName" class="text-danger"></span>
    </div>

    <div class="form-group">
        <label asp-for="DefaultAmount">Default Amount:</label>
        <input asp-for="DefaultAmount" type="number" class="form-control border-primary-subtle" />
        <span asp-validation-for="DefaultAmount" class="text-danger"></span>
    </div>

    <div class="form-group">
        <label asp-for="Description">Description:</label>
        <input asp-for="Description" class="form-control border-primary-subtle" />
        <span asp-validation-for="Description" class="text-danger"></span>
    </div>

    <div class="form-group d-inline-flex align-items-center gap-4 mt-3">
        <label asp-for="IsActive" class="form-check-label">Active:</label>
        <div class="form-check form-switch">
            
            <input asp-for="IsActive" class="form-check-input border-primary-subtle" type="checkbox" role="switch" />
        </div>
        <span asp-validation-for="IsActive" class="text-danger"></span>
    </div>

    <div class="mt-4">
        <button class="btn btn-primary" type="submit">Create</button>
        <a asp-action="Index" class="btn btn-secondary">Cancel</a>
    </div>

</form>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
