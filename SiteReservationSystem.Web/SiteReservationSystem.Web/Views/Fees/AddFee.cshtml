@model SiteReservationSystem.Web.Models.ReservationFee

@{
    ViewData["Title"] = "Add Fee";
}

<h2>Add Fee to Reservation</h2>

<h3>Reservation for @Model.Reservation?.Customer.FirstName @Model.Reservation?.Customer.LastName.</h3>
<div asp-validation-summary="All" class="text-danger"></div>
<form asp-action="AddFee" method="post">
    <input type="hidden" asp-for="ReservationID"/>
    <div class=" form-group">
        <label asp-for="FeeID">Select Fee Type: </label>
        <select asp-for="FeeID" asp-items="ViewBag.FeeList" class="form-control">
            <option value="">-- Select --</option>
        </select>
        <span asp-validation-for="FeeID" class="text-danger"></span>
    </div>
    <div class="form-group">
        <label asp-for="Amount">Amount: </label>
        <input asp-for="Amount" class="form-control" readonly/> 
        <span asp-validation-for="Amount" class="text-danger"></span>
    </div>
    <div class="form-group mt-2">
        <label asp-for="Notes">Notes:</label>
        <textarea asp-for="Notes" class="form-control"></textarea>
    </div>

    <div class="mt-4">
        <button class="btn btn-primary" type="submit">Add Fee</button>
        <a asp-controller="Reservations" asp-action="Index" asp-route-id="@Model.ReservationID" class="btn btn-secondary">Cancel</a> 
    </div>
</form>

@section Scripts {
    <script>
        const feeData = @Html.Raw(Json.Serialize(ViewBag.allFees));

        document.getElementById("FeeID").addEventListener("change", function () {
            const selectedId = this.ariaValueMax;
            const selectedFee = feeData.find(f => f.FeeID == selectedId);

            if (selectedFee){
                document.getElementById("Amount").value = selectedFee.defaultAmount;
            }
            else{
                document.getElementById("Amount").value = "";
            }
        });
    </script>
}