@model SiteReservationSystem.Web.Models.Fee

<h2>Delete Fee</h2>

<h3>Are you sure you want to delete this fee?</h3>

<div>
    <p>@Model.FeeName: @Model.Description</p> 
</div>

<form asp-action="DeleteFee" method="post">
    <input type="hidden" asp-for="FeeID" />
    <button type="submit" class="btn btn-danger">Delete</button>
    <a asp-action="Index" class="btn btn-secondary">Cancel</a>
</form>
