@{ ViewData["Title"] = "Fees"; }

<h2>Fees</h2>

<p>
    <a asp-action="CreateFee" class="btn" style="background: #2c3e6b; color:white">Create New Fee</a>
</p>

<table style="width: 100%; margin-top: 20px; border-collapse: collapse">
    <thead>
        <tr style="background: #2c3e6b; color: white">
            <th style="padding: 10px; text-align: left">Fee Name</th>
            <th style="padding: 10px; text-align: left">Default Amount</th>
            <th style="padding: 10px; text-align: left">Description</th>
            <th style="padding: 10px; text-align: left">Active</th>
            <th style="padding: 10px; text-align: left " colspan="3">Manage Fees</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var fee in ViewBag.Fees) {
        <tr style="border-bottom: 1px solid #ddd">
            <td style="padding: 10px">@fee.FeeName</td>
            <td style="padding: 10px">$@fee.DefaultAmount.ToString("0.00")</td>
            <td style="padding: 10px">@fee.Description</td>
            <td style="padding: 10px">@(fee.IsActive ? "Yes" : "No")</td>
            <td>
                <a asp-action="EditFee" asp-route-id="@fee.FeeID" class="btn btn-sm btn-primary">Edit</a>

                    <form asp-action="ToggleActive" asp-route-id="@fee.FeeID" method="post" style="display:inline;">
                        <button type="submit" class="btn btn-sm btn-secondary">
                            @(fee.IsActive ? "Inactive" : "Active")
                        </button>
                    </form>
                 <a asp-action="DeleteFee" asp-route-id="@fee.FeeID" class="btn btn-sm btn-danger">Delete</a>
            </td>
            </tr>
        }
    </tbody>
</table>
