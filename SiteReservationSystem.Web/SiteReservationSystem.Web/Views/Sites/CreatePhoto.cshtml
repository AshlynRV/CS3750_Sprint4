@model SiteReservationSystem.Web.Models.SitePhoto

@{
    ViewData["Title"] = "Add Photo";
}

<h2>Add Photo</h2>

<form asp-action="CreatePhoto" method="post">
    <input type="hidden" asp-for="SiteID" />

    <div class="form-group">
        <label asp-for="PhotoURL">Photo URL</label>
        <input asp-for="PhotoURL" class="form-control" />
        <span asp-validation-for="PhotoURL" class="text-danger"></span>
    </div>

    <div class="form-group">
        <label asp-for="Caption" style="padding-top: 10px"></label>
        <input asp-for="Caption" class="form-control" />
    </div>

    <br />

    <button type="submit" class="btn btn-primary">Add Photo</button>
    <a asp-action="Details" asp-route-id="@Model.SiteID" class="btn btn-secondary">Cancel</a>
</form>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}