@model SiteReservationSystem.Web.ViewModels.CreateReservationViewModel
@{
    var maxLength = ViewBag.MaxLengthFeet ?? 0;
    var isPCS = Context.Session.GetInt32("IsPCSOrders") == 1;
}

<h2 class="mb-4">Reserve Site</h2>

<div class="row">


    <div class="col-md-7">
        <form asp-action="Reserve" method="post" class="card p-4 shadow-sm" onsubmit="return validateReservation()">

            <input type="hidden" asp-for="SiteID" />

            <div class="mb-3">
                <label class="form-label">Start Date</label>
                <input asp-for="StartDate" type="date" class="form-control" min="@DateTime.Today.AddDays(1).ToString("yyyy-MM-dd")" />
            </div>

            <div class="mb-3">
                <label class="form-label">End Date</label>
                <input asp-for="EndDate" type="date" class="form-control" min="@DateTime.Today.AddDays(1).ToString("yyyy-MM-dd")" />
            </div>

            <div class="mb-3">
                <label class="form-label">Trailer Length</label>
                <input asp-for="TrailerLengthFeet" type="number" class="form-control" id="trailerLength" min="0" />
                <small class="text-danger" id="trailerError"></small>
            </div>

            <div class="mb-3">
                <label class="form-label">Number of Guests</label>
                <input asp-for="NumberOfGuests" type="number" class="form-control" value="1" min="0" />
            </div>

            <div class="mb-3">
                <label class="form-label">Number of Pets</label>
                <input asp-for="NumberOfPets" type="number" class="form-control" value="0" min="0" />
            </div>

            <div class="mb-3">
                <label class="form-label">Special Requests</label>
                <textarea asp-for="SpecialRequests" class="form-control" rows="3"></textarea>
            </div>

            <button type="submit" class="btn btn-success w-100">
                Confirm Reservation
            </button>

        </form>
    </div>


    <div class="col-md-5">

        <div class="card p-4 shadow-sm bg-light">

            <h5>Reservation Info</h5>
            <hr />

            <p><strong>Site Number:</strong> @Model.SiteNumber</p>

            <p class="text-muted">
                Please review your reservation details before submitting.
            </p>

        </div>

    </div>

</div>

@section Scripts {
    <script>
        var maxLength = @maxLength;
        var isPCS = @isPCS.ToString().ToLower();

        function isPeakSeason(date) {
            var month = date.getMonth();
            return month >= 3 && month <= 9;
        }

        function limitEndDate() {
            var startInput = document.getElementById('StartDate');
            var endInput = document.getElementById('EndDate');
            var tomorrow = new Date();
            tomorrow.setDate(tomorrow.getDate() + 1);

            if (!startInput.value) {
                startInput.value = tomorrow.toISOString().split('T')[0];
            }

            startInput.min = tomorrow.toISOString().split('T')[0];

            var startDate = new Date(startInput.value);
            var minEnd = new Date(startDate);
            minEnd.setDate(minEnd.getDate() + 1);
            endInput.min = minEnd.toISOString().split('T')[0];

            if (isPeakSeason(startDate) && !isPCS) {
                var maxStay = 14;
                var maxEnd = new Date(startDate);
                maxEnd.setDate(maxEnd.getDate() + maxStay);
                endInput.max = maxEnd.toISOString().split('T')[0];

                var currentEnd = new Date(endInput.value);
                if (currentEnd > maxEnd) {
                    endInput.value = maxEnd.toISOString().split('T')[0];
                }
            } else {
                endInput.removeAttribute('max');
            }
        }

        document.getElementById('StartDate')?.addEventListener('change', limitEndDate);

        window.onload = function() {
            limitEndDate();
        };

        function validateReservation() {
            var startDate = new Date(document.getElementById('StartDate').value);
            var endDate = new Date(document.getElementById('EndDate').value);
            var trailerLength = parseInt(document.getElementById('trailerLength').value) || 0;
            var today = new Date();
            today.setHours(0, 0, 0, 0);
            var tomorrow = new Date(today);
            tomorrow.setDate(tomorrow.getDate() + 1);

            document.getElementById('trailerError').textContent = '';

            if (startDate < tomorrow) {
                alert('Start date must be at least tomorrow.');
                return false;
            }

            if (endDate <= startDate) {
                alert('End date must be after start date.');
                return false;
            }

            if (trailerLength > maxLength) {
                document.getElementById('trailerError').textContent = 'Trailer length exceeds maximum allowed (' + maxLength + ' feet) for this site.';
                return false;
            }

            var stayLength = Math.ceil((endDate - startDate) / (1000 * 60 * 60 * 24));
            var isPeak = isPeakSeason(startDate);

            if (!isPCS && isPeak && stayLength > 14) {
                alert('Maximum stay is 14 days during peak season.');
                return false;
            }

            return true;
        }
    </script>
}