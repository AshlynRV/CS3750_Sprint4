@{
    ViewData["Title"] = "Login";
}

<div style="max-width: 400px; margin: 80px auto;">
    <h2>RV Park Login</h2>

    @if (TempData["Message"] != null)
    {
        <div style="color: green; margin-bottom: 12px;">@TempData["Message"]</div>
    }

    <p>Sign in to continue.</p>

    <!-- Display error if there is one -->
    @if (ViewBag.Error != null)
    {
        <div style="color: red; margin-bottom: 12px;">@ViewBag.Error</div>
    }

    <form method="post" action="/Account/Login">
        <div style="margin-bottom: 12px;">
            <label>Email</label><br />
            <input type="email" name="email" style="width:100%; padding:8px;" required />
        </div>
        <div style="margin-bottom: 12px;">
            <label>Password</label><br />
            <input type="password" name="password" style="width:100%; padding:8px;" required />
        </div>
        <button type="submit" class="btn btn-primary mb-3">Login</button>
    </form>
    <div>Don't have an account? <a asp-action="Register">Create one</a></div>
</div>

