@model IEnumerable<SiteReservationSystem.Web.Models.Employee>

@{
    ViewData["Title"] = "Employees";
}

<h2>Employees</h2>

<p>
    <a asp-action="CreateEmployee" class="btn btn-primary">Create New Employee</a>
</p>

<table class="table table-striped">
    <thead>
        <tr>
            <th>First Name</th>
            <th>Last Name</th>
            <th>Email</th>
            <th>Permissions</th>
            <th>Locked Out</th>
            <th>Actions</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var emp in Model)
        {
            <tr>
                <td>@emp.FirstName</td>
                <td>@emp.LastName</td>
                <td>@emp.User?.Email</td>
                <td>@emp.AccessPermissions</td>
                <td>@emp.IsLockedOut</td>
                <td>
                    <a asp-action="EditEmployee" asp-route-id="@emp.EmployeeID" class="btn btn-sm btn-warning">Edit</a>
                    
                    <form asp-action="ToggleLock" asp-route-id="@emp.EmployeeID" method="post" style="display:inline;">
                        <button type="submit" class="btn btn-sm btn-danger">
                            @(emp.IsLockedOut ? "Unlock" : "Lock")
                        </button>
                    </form>
                    
                    <a asp-action="DeleteEmployee" asp-route-id="@emp.EmployeeID" class="btn btn-sm btn-secondary">Delete</a>
                </td>
            </tr>
        }
    </tbody>
</table>