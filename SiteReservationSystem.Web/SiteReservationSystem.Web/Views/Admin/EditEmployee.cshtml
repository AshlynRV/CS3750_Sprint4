@model SiteReservationSystem.Web.ViewModels.EmployeeViewModel

@{
    ViewData["Title"] = "Edit Employee";
}

<h2>Edit Employee</h2>

<form asp-action="EditEmployee" method="post">
    <input type="hidden" asp-for="EmployeeID" />

    <div class="form-group">
        <label asp-for="FirstName"></label>
        <input asp-for="FirstName" class="form-control" />
        <span asp-validation-for="FirstName" class="text-danger"></span>
    </div>

    <div class="form-group">
        <label asp-for="LastName"></label>
        <input asp-for="LastName" class="form-control" />
        <span asp-validation-for="LastName" class="text-danger"></span>
    </div>

    <div class="form-group">
        <label asp-for="Email"></label>
        <input asp-for="Email" class="form-control" />
        <span asp-validation-for="Email" class="text-danger"></span>
    </div>

    <!-- Permissions checkboxes -->
    <div class="form-group">
        <label style="font-weight: 600; font-size: 1.4rem;">Permissions</label>
        @foreach (AccessPermissions perm in Enum.GetValues(typeof(AccessPermissions)).Cast<AccessPermissions>().Where(p => p != AccessPermissions.None))
        {
            <div class="form-check">
                <input class="form-check-input" type="checkbox"
                       name="SelectedPermissions"
                       value="@perm"
                @(Model.SelectedPermissions.Contains(perm) ? "checked" : "") />
                <label class="form-check-label">@perm</label>
            </div>
        }
    </div>

    <div class="form-group form-check" style="margin-top: 1rem;">
        <input asp-for="IsLockedOut" class="form-check-input" />
        <label asp-for="IsLockedOut" class="form-check-label"></label>
    </div>

    <button type="submit" class="btn btn-primary">Save Changes</button>
    <a asp-action="Employees" class="btn btn-secondary">Cancel</a>
</form>

@section Scripts {
    @await Html.PartialAsync("_ValidationScriptsPartial")
}
